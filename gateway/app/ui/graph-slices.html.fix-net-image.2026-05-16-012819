<script>
(function () {
  if (window.__graphBuilderUnitPatchInstalled) return;
  window.__graphBuilderUnitPatchInstalled = true;

  const token = localStorage.getItem("token") || "";

  let allImages = [];

  function esc(s) {
    return String(s ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function fmt(n) {
    const num = Number(n || 0);
    if (!Number.isFinite(num)) return "";
    let s = num.toFixed(2);
    s = s.replace(/\.00$/, "");
    s = s.replace(/(\.\d)0$/, "$1");
    return s;
  }

  async function fetchAllImages() {
    const endpoints = ["/api/images", "/images"];
    for (const url of endpoints) {
      try {
        const res = await fetch(url, {
          headers: token ? { Authorization: `Bearer ${token}` } : {}
        });
        if (!res.ok) continue;
        const data = await res.json();
        const arr = Array.isArray(data)
          ? data
          : Array.isArray(data?.items)
            ? data.items
            : [];
        const names = arr
          .map(item => {
            if (typeof item === "string") return item;
            return item?.name || item?.filename || item?.stored_filename || "";
          })
          .filter(Boolean);

        if (names.length) {
          allImages = [...new Set(names)].sort((a, b) => a.localeCompare(b));
          enhanceNodeRows();
          return;
        }
      } catch (err) {
        console.warn("No pude cargar imágenes desde", url, err);
      }
    }
  }

  function setHeaders() {
    document.querySelectorAll("thead th").forEach(th => {
      const t = th.textContent.trim();
      if (t === "RAM MB") th.textContent = "RAM GB";
    });
  }

  function enhanceNodeRows() {
    setHeaders();

    const rows = [...document.querySelectorAll("#nodesBody tr")];
    rows.forEach((tr) => {
      const tds = tr.querySelectorAll("td");
      if (tds.length < 7) return;

      const imageSelect = tds[1]?.querySelector("select");
      const vcpuInput   = tds[2]?.querySelector("input");
      const ramInput    = tds[3]?.querySelector("input");
      const diskInput   = tds[4]?.querySelector("input");
      const workerSel   = tds[5]?.querySelector("select");
      const internetChk = tds[6]?.querySelector('input[type="checkbox"]');

      if (imageSelect && allImages.length) {
        const current = imageSelect.value;
        const existing = [...imageSelect.options].map(o => o.value);
        const needsRefresh =
          existing.length !== allImages.length ||
          allImages.some(x => !existing.includes(x));

        if (needsRefresh) {
          imageSelect.innerHTML = allImages
            .map(name => `<option value="${esc(name)}">${esc(name)}</option>`)
            .join("");
          if (allImages.includes(current)) {
            imageSelect.value = current;
          }
        }
      }

      if (vcpuInput) {
        vcpuInput.min = "1";
        vcpuInput.step = "1";
      }

      if (ramInput) {
        ramInput.type = "number";
        ramInput.step = "0.25";
        ramInput.min = "0.25";
        ramInput.placeholder = "GB";

        if (!ramInput.dataset.gbNormalized) {
          const raw = parseFloat(ramInput.value || "0");
          if (raw > 64) {
            ramInput.value = fmt(raw / 1024);
          }
          ramInput.dataset.gbNormalized = "1";
        }
      }

      if (diskInput) {
        diskInput.type = "number";
        diskInput.step = "0.1";
        diskInput.min = "0.1";
        diskInput.placeholder = "GB";
      }

      if (workerSel) workerSel.dataset.enhanced = "1";
      if (internetChk) internetChk.dataset.enhanced = "1";
    });
  }

  function captureNodesFromDom() {
    const rows = [...document.querySelectorAll("#nodesBody tr")];
    const prev = Array.isArray(window.state?.nodes) ? window.state.nodes : [];

    return rows.map((tr, index) => {
      const tds = tr.querySelectorAll("td");
      const oldNode = prev[index] || {};

      const nameInput  = tds[0]?.querySelector("input");
      const imageSel   = tds[1]?.querySelector("select");
      const vcpuInput  = tds[2]?.querySelector("input");
      const ramInput   = tds[3]?.querySelector("input");
      const diskInput  = tds[4]?.querySelector("input");
      const workerSel  = tds[5]?.querySelector("select");
      const internetCb = tds[6]?.querySelector('input[type="checkbox"]');

      const ramGb = parseFloat(ramInput?.value || "0") || 0;
      const diskGb = parseFloat(diskInput?.value || "0") || 0;
      const vcpus = parseInt(vcpuInput?.value || oldNode.vcpus || oldNode.vcpu || 1, 10) || 1;

      return {
        ...oldNode,
        name: (nameInput?.value || oldNode.name || `n${index + 1}`).trim(),
        image: imageSel?.value || oldNode.image || oldNode.image_name || "",
        image_name: imageSel?.value || oldNode.image_name || oldNode.image || "",
        vcpus,
        vcpu: vcpus,
        ram_gb: ramGb,
        ram_mb: Math.max(128, Math.round(ramGb * 1024)),
        disk_gb: diskGb,
        worker: workerSel?.value || oldNode.worker || "auto",
        internet: !!internetCb?.checked
      };
    });
  }

  function wrapSaveGraphSlice() {
    if (typeof window.saveGraphSlice !== "function") return;
    if (window.saveGraphSlice.__unitWrapped) return;

    const original = window.saveGraphSlice;

    window.saveGraphSlice = async function (...args) {
      try {
        if (window.state) {
          window.state.nodes = captureNodesFromDom();
        }
      } catch (err) {
        console.warn("No pude convertir nodos antes de guardar:", err);
      }
      return original.apply(this, args);
    };

    window.saveGraphSlice.__unitWrapped = true;
  }

  function installObserver() {
    const body = document.getElementById("nodesBody");
    if (!body) return;

    const mo = new MutationObserver(() => {
      enhanceNodeRows();
      wrapSaveGraphSlice();
    });

    mo.observe(body, { childList: true, subtree: true });
  }

  function boot() {
    setHeaders();
    fetchAllImages();
    enhanceNodeRows();
    wrapSaveGraphSlice();
    installObserver();

    setInterval(() => {
      enhanceNodeRows();
      wrapSaveGraphSlice();
    }, 1500);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
})();
</script>
