<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <title>Graph slices · PUCP Private Cloud</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/static/app.css">

  <link rel="stylesheet" href="https://unpkg.com/xterm/css/xterm.css">
  <script src="https://unpkg.com/xterm/lib/xterm.js"></script>
  <script src="https://unpkg.com/xterm-addon-fit/lib/xterm-addon-fit.js"></script>

  <style>
    .vm-clickable{cursor:pointer;transition:.18s transform,.18s border-color,.18s background}
    .vm-clickable:hover{transform:translateY(-1px);border-color:rgba(91,140,255,.32);background:#122044}

    .modal-backdrop{position:fixed;inset:0;background:rgba(3,8,20,.68);backdrop-filter:blur(6px);z-index:9998;display:none;align-items:center;justify-content:center;padding:20px}
    .modal-backdrop.show{display:flex}
    .modal-card{width:min(980px,100%);max-height:90vh;overflow:auto;background:linear-gradient(180deg,#101935,#0d1530);border:1px solid rgba(255,255,255,.08);border-radius:24px;box-shadow:0 20px 50px rgba(0,0,0,.38)}
    .modal-header{padding:18px 20px 14px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}
    .modal-title{margin:0;font-size:22px}
    .modal-subtitle{margin:6px 0 0;color:var(--muted);font-size:13px}
    .modal-body{padding:18px 20px 20px;display:grid;grid-template-columns:1.1fr .9fr;gap:18px}
    .detail-box{background:#0d1530;border:1px solid rgba(255,255,255,.06);border-radius:18px;padding:14px}
    .detail-box h3{margin:0 0 12px;font-size:15px}
    .kv{display:grid;grid-template-columns:160px 1fr;gap:8px 12px;font-size:13px}
    .kv div:nth-child(odd){color:var(--muted);font-weight:600}
    .iface-card{background:#101936;border:1px solid rgba(255,255,255,.05);border-radius:14px;padding:10px 12px;margin-top:10px;font-size:12px;line-height:1.55}
    .code-block{margin-top:10px;background:#071126;border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:12px;font-family:ui-monospace,SFMono-Regular,Consolas,monospace;font-size:12px;white-space:pre-wrap;word-break:break-word}
    .tag-list{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .tag{padding:7px 10px;border-radius:999px;background:#152141;border:1px solid rgba(255,255,255,.06);color:#dce7ff;font-size:12px}
    .actions-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
    .links-list{display:flex;flex-direction:column;gap:10px}

    .terminal-shell{width:min(1200px,100%);max-height:92vh;overflow:hidden}
    .terminal-body{padding:0}
    .terminal-toolbar{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.06);background:#111a37;flex-wrap:wrap}
    .terminal-status{font-size:12px;color:var(--muted)}
    #terminalMount{height:460px;background:#050b18;padding:10px}

    .builder-status{margin-top:12px;padding:10px 12px;border-radius:12px;background:#132142;border:1px solid rgba(255,255,255,.06);font-size:13px}
    .builder-status strong{color:#fff}

    .selected-shell{display:flex;flex-direction:column;gap:14px}
    .selected-toolbar{display:flex;gap:10px;flex-wrap:wrap;align-items:end}
    .selected-toolbar .field{flex:1;min-width:220px}
    .summary-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .summary-card{background:#101936;border:1px solid rgba(255,255,255,.06);border-radius:18px;padding:14px}
    .summary-card h4{margin:0 0 6px;font-size:12px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.04em}
    .summary-card strong{font-size:22px}
    .summary-card span{display:block;margin-top:4px;color:var(--muted);font-size:12px}

    .topology-stage{
      background:radial-gradient(circle at top,#13224a 0%,#0b132c 70%);
      border:1px solid rgba(255,255,255,.06);
      border-radius:20px;
      padding:14px;
      min-height:360px;
    }

    .legend-row{display:flex;gap:10px;flex-wrap:wrap}
    .legend-item{
      display:flex;align-items:center;gap:8px;
      background:#101936;border:1px solid rgba(255,255,255,.06);
      color:#dbe6ff;padding:8px 12px;border-radius:999px;font-size:12px
    }
    .legend-swatch{
      width:12px;height:12px;border-radius:50%
    }

    .slice-node-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:12px}
    .slice-node-card{
      border:1px solid rgba(255,255,255,.07);
      background:#101936;
      border-radius:18px;
      padding:14px;
      cursor:pointer;
      transition:.18s transform,.18s border-color,.18s background;
    }
    .slice-node-card:hover{transform:translateY(-1px);border-color:rgba(91,140,255,.28);background:#122044}
    .slice-node-head{display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:10px}
    .device-icon{
      width:42px;height:42px;border-radius:14px;display:grid;place-items:center;
      background:#17274b;border:1px solid rgba(255,255,255,.08);font-size:20px
    }
    .node-role-badge{
      padding:6px 10px;border-radius:999px;font-size:11px;font-weight:700;
      border:1px solid rgba(255,255,255,.08);background:#152141;color:#dce7ff
    }
    .node-role-badge.gateway{background:rgba(244,183,64,.16);border-color:rgba(244,183,64,.28);color:#ffe7a8}
    .node-role-badge.vm{background:rgba(91,140,255,.14);border-color:rgba(91,140,255,.24);color:#dce7ff}
    .status-pill{
      display:inline-flex;align-items:center;gap:7px;padding:6px 10px;border-radius:999px;
      font-size:11px;font-weight:700;border:1px solid rgba(255,255,255,.08);background:#152141;color:#dce7ff
    }
    .status-dot{width:8px;height:8px;border-radius:50%}
    .status-running .status-dot{background:var(--success)}
    .status-error .status-dot{background:var(--danger)}
    .status-planned .status-dot{background:var(--warning)}
    .status-other .status-dot{background:#9eb0d4}

    .node-meta-grid{
      display:grid;
      grid-template-columns:110px 1fr;
      gap:6px 10px;
      font-size:12px;
      margin-top:10px
    }
    .node-meta-grid div:nth-child(odd){color:var(--muted);font-weight:600}

    .slice-card.active{
      border-color:rgba(91,140,255,.28);
      background:#132142;
      box-shadow:0 10px 24px rgba(91,140,255,.12)
    }
    .slice-head{
      display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap
    }
    .slice-head-main h3{margin:0 0 6px}
    .slice-actions{display:flex;gap:8px;flex-wrap:wrap}
    .slice-mini-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .slice-mini-tag{
      padding:6px 10px;border-radius:999px;border:1px solid rgba(255,255,255,.07);
      background:#0d1530;color:#dce7ff;font-size:11px
    }

    .vm-box-compact{
      display:grid;
      grid-template-columns:42px 1fr;
      gap:10px;
      align-items:center;
      background:#0d1530;
      border:1px solid rgba(255,255,255,.06);
      border-radius:14px;
      padding:10px 12px;
      margin-top:10px;
      font-size:12px;
      cursor:pointer;
      transition:.18s transform,.18s border-color,.18s background
    }
    .vm-box-compact:hover{transform:translateY(-1px);border-color:rgba(91,140,255,.28);background:#122044}
    .vm-box-compact strong{display:block;margin-bottom:3px}
    .vm-box-sub{color:var(--muted);font-size:11px}

    .svg-empty{
      min-height:260px;display:grid;place-items:center;color:var(--muted);
      border:1px dashed rgba(255,255,255,.12);border-radius:18px
    }

    .icon-action-btn{
      min-width:42px;
      height:34px;
      padding:0 10px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:12px;
      font-size:16px;
      font-weight:700;
      line-height:1;
    }

    .quick-actions-inline{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      margin-top:12px;
    }

    .quick-actions-inline .icon-action-btn{
      min-width:34px;
      width:34px;
      height:30px;
      padding:0;
      border-radius:10px;
      font-size:14px;
    }

    .vm-box-compact{
      position:relative;
    }

    .vm-box-compact .quick-actions-inline{
      margin-top:8px;
    }

    @media (max-width:1100px){
      .summary-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    }
    @media (max-width:920px){
      .modal-body{grid-template-columns:1fr}
      .kv{grid-template-columns:1fr}
      #terminalMount{height:340px}
    }
    @media (max-width:760px){
      .summary-grid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-badge">☁</div>
        <div>
          <h2>PUCP Cloud</h2>
          <p>Topologías arbitrarias</p>
        </div>
      </div>
      <nav class="nav">
        <a href="/dashboard.html" data-nav="dashboard">Dashboard</a>
        <a href="/images.html" data-nav="images">Imágenes</a>
        <a href="/slices.html" data-nav="slices">Slices legacy</a>
        <a href="/graph-slices.html" data-nav="graph">Graph slices</a>
        <a href="/monitoring.html" data-nav="monitoring">Monitoreo</a>
      </nav>
      <div class="sidebar-bottom">
        <div class="user-pill">Sesión: <strong data-user-name>admin</strong></div>
        <button class="btn-danger logout-btn" data-logout>Cerrar sesión</button>
      </div>
    </aside>

    <main class="main">
      <div class="topbar">
        <div>
          <h1 class="page-title">Graph slices</h1>
          <p class="page-subtitle">Builder + selector de slices + detalle de VMs</p>
        </div>
        <div class="chips">
          <span class="chip ok">graph mode</span>
          <span class="chip" id="graphCountChip">0 graph slices</span>
          <span class="chip" id="selectedSliceChip">sin slice seleccionado</span>
          <span class="chip" id="autoRefreshChip">auto refresh: on</span>
          <span class="chip" id="lastRefreshChip">última actualización: --</span>
        </div>
      </div>

      <div class="grid grid-2">
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Builder</h2>
            <p class="card-subtitle">Configuración de la topología</p>
          </div>
          <div class="card-body">
            <div class="form-grid">
              <div class="field">
                <label>Nombre</label>
                <input id="slice_name" value="graph-ui-01">
              </div>
              <div class="field">
                <label>VLAN base</label>
                <input id="vlan_base" type="number" value="350">
              </div>
              <div class="field">
                <label>VNC inicial</label>
                <input id="vnc_start" type="number" value="6031">
              </div>
              <div class="field">
                <label>Network backend</label>
                <select id="network_backend">
                  <option value="vlan" selected>vlan</option>
                  <option value="vxlan">vxlan</option>
                </select>
              </div>
              <div class="field full">
                <label>Internet mode</label>
                <select id="internet_mode">
                  <option value="none" selected>none</option>
                  <option value="headnode_nat">headnode_nat</option>
                </select>
              </div>
            </div>

            <div class="toolbar" style="margin-top:16px">
              <button class="btn-secondary btn-small" onclick="loadSampleLinear()">2 Ubuntu</button>
              <button class="btn-secondary btn-small" onclick="loadSampleNat()">2 Ubuntu + NAT</button>
              <button class="btn-secondary btn-small" onclick="loadSampleRing()">Ring 4</button>
              <button class="btn-danger btn-small" onclick="resetBuilder()">Reset</button>
            </div>

            <div class="builder-status" id="builderStatus">
              <strong>Modo:</strong> crear nuevo slice
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Respuesta</h2>
            <p class="card-subtitle">Salida del backend</p>
          </div>
          <div class="card-body">
            <pre id="output">Esperando acción...</pre>
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:20px">
        <div class="card-header">
          <h2 class="card-title">Nodos</h2>
          <p class="card-subtitle">Imagen, recursos y worker preferido</p>
        </div>
        <div class="card-body">
          <div class="toolbar" style="margin-bottom:14px">
            <button class="btn-success btn-small" onclick="addNode()">+ Nodo</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Imagen</th>
                  <th>vCPU</th>
                  <th>RAM GB</th>
                  <th>Disco GB</th>
                  <th>Worker</th>
                  <th>Internet</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="nodesBody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:20px">
        <div class="card-header">
          <h2 class="card-title">Enlaces</h2>
        </div>
        <div class="card-body">
          <div class="toolbar" style="margin-bottom:14px">
            <button class="btn-success btn-small" onclick="addLink()">+ Enlace</button>
            <button class="btn-secondary btn-small" onclick="generateLinearLinks()">Autolineal</button>
            <button class="btn-secondary btn-small" onclick="generateRingLinks()">Autoanillo</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Desde</th>
                  <th>Hasta</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="linksBody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="grid grid-2" style="margin-top:20px">
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Vista previa del builder</h2>
            <p class="card-subtitle">Topología local antes de guardar</p>
          </div>
          <div class="card-body">
            <div class="preview-box">
              <div id="previewWrap" class="svg-wrap"></div>
            </div>
            <div class="toolbar" style="margin-top:16px">
              <button class="btn-primary" id="saveBtn" onclick="saveGraphSlice()">Crear graph slice</button>
              <button class="btn-secondary" onclick="loadGraphSlices()">Refrescar</button>
              <button class="btn-danger" id="cancelEditBtn" style="display:none" onclick="cancelEdit()">Cancelar edición</button>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Slice seleccionado</h2>
            <p class="card-subtitle">Topología real y resumen operativo</p>
          </div>
          <div class="card-body">
            <div class="selected-shell">
              <div class="selected-toolbar">
                <div class="field">
                  <label>Elegir slice</label>
                  <select id="sliceSelector" onchange="setSelectedSlice(this.value)"></select>
                </div>
                <div class="toolbar">
                  <button class="btn-secondary btn-small" onclick="loadGraphSlices()">Refrescar</button>
                  <button class="btn-primary btn-small" onclick="editSelectedSlice()">Editar en builder</button>
                </div>
              </div>

              <div id="selectedSliceSummary" class="summary-grid"></div>

              <div class="legend-row">
                <div class="legend-item"><span class="legend-swatch" style="background:#7aa3ff"></span> VM</div>
                <div class="legend-item"><span class="legend-swatch" style="background:#f4b740"></span> Gateway / Internet</div>
                <div class="legend-item"><span class="legend-swatch" style="background:#1fc97c"></span> Running</div>
              </div>

              <div class="topology-stage">
                <div id="selectedSliceTopology"></div>
              </div>

              <div>
                <h3 style="margin:0 0 12px">VMs del slice</h3>
                <div id="selectedSliceNodes" class="slice-node-list"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:20px">
        <div class="card-header">
          <h2 class="card-title">Graph slices existentes</h2>
          <p class="card-subtitle">Selecciona un slice o entra al detalle de una VM</p>
        </div>
        <div class="card-body">
          <div id="graphList" class="slice-list"></div>
        </div>
      </div>
    </main>
  </div>

  <div id="vmModal" class="modal-backdrop" onclick="closeVmModal(event)">
    <div class="modal-card" onclick="event.stopPropagation()">
      <div class="modal-header">
        <div>
          <h2 class="modal-title" id="vmModalTitle">Detalle VM</h2>
          <p class="modal-subtitle" id="vmModalSubtitle">Información de la máquina virtual desplegada</p>
        </div>
        <div class="toolbar">
          <button class="btn-secondary btn-small" onclick="closeVmModal()">Cerrar</button>
        </div>
      </div>
      <div class="modal-body">
        <div class="detail-box">
          <h3>Datos generales</h3>
          <div class="kv" id="vmGeneralInfo"></div>

          <div class="tag-list" id="vmTags"></div>

          <div class="actions-row">
            <button class="btn-secondary btn-small" onclick="copyTunnelCommand()">Copiar túnel SSH</button>
            <button class="btn-secondary btn-small" onclick="copyVncTarget()">Copiar destino VNC</button>
            <button class="btn-primary btn-small" onclick="openVncTarget()">Abrir VNC</button>
            <button class="btn-primary btn-small" onclick="openNoVncConsole()">Consola gráfica</button>
            <button class="btn-success btn-small" onclick="openVmSerialConsole()">Terminal VM</button>
            <button class="btn-secondary btn-small" onclick="openWorkerTerminal()">Terminal worker</button>
          </div>

          <div class="actions-row">
            <button class="btn-success btn-small icon-action-btn" title="Encender" aria-label="Encender" onclick="performVmAction('start')">⏻</button>
            <button class="btn-danger btn-small icon-action-btn" title="Apagar" aria-label="Apagar" onclick="performVmAction('stop')">⏹</button>
            <button class="btn-secondary btn-small icon-action-btn" title="Reiniciar" aria-label="Reiniciar" onclick="performVmAction('reboot')">↻</button>
            <button class="btn-secondary btn-small icon-action-btn" title="Pausar" aria-label="Pausar" onclick="performVmAction('pause')">⏸</button>
            <button class="btn-secondary btn-small icon-action-btn" title="Reanudar" aria-label="Reanudar" onclick="performVmAction('resume')">▶</button>
          </div>

          <div class="code-block" id="vmTunnelCommand">Sin comando disponible</div>
        </div>

        <div class="detail-box">
          <h3>Interfaces</h3>
          <div id="vmInterfaces" class="links-list"></div>
        </div>
      </div>
    </div>
  </div>

  <div id="terminalModal" class="modal-backdrop" onclick="closeTerminalModal(event)">
    <div class="modal-card terminal-shell" onclick="event.stopPropagation()">
      <div class="terminal-toolbar">
        <div>
          <div class="modal-title" id="terminalTitle" style="font-size:20px">Terminal worker</div>
          <div class="terminal-status" id="terminalStatus">Desconectada</div>
        </div>
        <div class="toolbar">
          <button class="btn-secondary btn-small" onclick="clearTerminal()">Limpiar</button>
          <button class="btn-danger btn-small" onclick="closeTerminalModal()">Cerrar terminal</button>
        </div>
      </div>
      <div class="terminal-body">
        <div id="terminalMount"></div>
      </div>
    </div>
  </div>

  <script src="/static/app.js"></script>
  <script>
    CloudUI.requireAuth();
    CloudUI.setupLayout("graph");

    const state = {
      nodes: [],
      links: [],
      graphSlices: [],
      selectedVm: null,
      editingSliceName: null,
      selectedSliceName: null
    };

    const workers = ["", "server1", "server2", "server3"];
    const images = ["cirros-base.img", "ubuntu-20.04-server-cloudimg-amd64.img"];

    const WORKER_PORT_MAP = {
      server1: 5801,
      server2: 5802,
      server3: 5803
    };

    const AUTO_REFRESH_MS = 12000;
    let autoRefreshTimer = null;

    let terminalInstance = null;
    let fitAddon = null;
    let terminalSocket = null;
    let terminalResizeHandler = null;

    function effectiveGatewayHost() {
      const h = window.location.hostname || "10.20.12.70";
      if (h === "127.0.0.1" || h === "localhost") return "10.20.12.70";
      return h;
    }

    function escapeAttr(value) {
      return String(value ?? "").replace(/"/g, "&quot;");
    }

    function setGraphCount(n) {
      document.getElementById("graphCountChip").textContent = `${n} graph slices`;
    }

    function setSelectedSliceChip(text) {
      document.getElementById("selectedSliceChip").textContent = text;
    }

    function setLastRefreshLabel(date = new Date()) {
      const el = document.getElementById("lastRefreshChip");
      if (!el) return;
      const hh = String(date.getHours()).padStart(2, "0");
      const mm = String(date.getMinutes()).padStart(2, "0");
      const ss = String(date.getSeconds()).padStart(2, "0");
      el.textContent = `última actualización: ${hh}:${mm}:${ss}`;
    }

    function captureUiContext() {
      const vmModalOpen = document.getElementById("vmModal")?.classList.contains("show");
      return {
        selectedSliceName: state.selectedSliceName,
        vmModalOpen,
        selectedVm: state.selectedVm
          ? {
              sliceName: state.selectedVm.slice?.slice_name || null,
              vmName: state.selectedVm.vm?.name || null
            }
          : null
      };
    }

    function restoreUiContext(ctx) {
      if (!ctx) return;
      if (ctx.selectedSliceName) {
        state.selectedSliceName = ctx.selectedSliceName;
      }
      syncSelectedSlice(true);

      if (ctx.vmModalOpen && ctx.selectedVm?.sliceName && ctx.selectedVm?.vmName) {
        reopenVmDetailByName(ctx.selectedVm.sliceName, ctx.selectedVm.vmName);
      }
    }

    async function silentRefreshGraphSlices() {
      try {
        const ctx = captureUiContext();
        const data = await CloudUI.api("/api/graph-slices");
        state.graphSlices = data || [];
        setGraphCount(state.graphSlices.length);
        restoreUiContext(ctx);
        setLastRefreshLabel();
      } catch (err) {
        console.warn("Auto refresh graph slices falló:", err);
      }
    }

    function startAutoRefresh() {
      const chip = document.getElementById("autoRefreshChip");
      if (chip) chip.textContent = "auto refresh: on";

      if (autoRefreshTimer) clearInterval(autoRefreshTimer);

      autoRefreshTimer = setInterval(() => {
        if (document.visibilityState === "hidden") return;
        silentRefreshGraphSlices();
      }, AUTO_REFRESH_MS);
    }

    function stopAutoRefresh() {
      const chip = document.getElementById("autoRefreshChip");
      if (chip) chip.textContent = "auto refresh: off";

      if (autoRefreshTimer) {
        clearInterval(autoRefreshTimer);
        autoRefreshTimer = null;
      }
    }

    function normalizeVmStatus(vm) {
      const status = (vm?.status || "").toLowerCase();
      if (status === "running") return "running";
      if (status === "error") return "error";
      if (status === "planned") return "planned";
      return "other";
    }

    function statusPillHtml(statusText) {
      const status = (statusText || "").toLowerCase();
      const cls =
        status === "running" ? "status-running" :
        status === "error" ? "status-error" :
        status === "planned" ? "status-planned" :
        "status-other";
      return `<span class="status-pill ${cls}"><span class="status-dot"></span>${CloudUI.escapeHtml(statusText || "unknown")}</span>`;
    }

    function getSliceByName(name) {
      return state.graphSlices.find(s => s.slice_name === name) || null;
    }

    function getSelectedSlice() {
      if (!state.graphSlices.length) return null;
      return getSliceByName(state.selectedSliceName) || state.graphSlices[0];
    }

    function syncSelectedSlice(defaultToFirst = true) {
      if (!state.graphSlices.length) {
        state.selectedSliceName = null;
        setSelectedSliceChip("sin slice seleccionado");
        renderSliceSelector();
        renderSelectedSliceView();
        renderGraphList();
        return;
      }

      const exists = state.graphSlices.some(s => s.slice_name === state.selectedSliceName);
      if (!exists && defaultToFirst) {
        state.selectedSliceName = state.graphSlices[0].slice_name;
      }

      const selected = getSelectedSlice();
      setSelectedSliceChip(selected ? `seleccionado: ${selected.slice_name}` : "sin slice seleccionado");
      renderSliceSelector();
      renderSelectedSliceView();
      renderGraphList();
    }

    function setSelectedSlice(name) {
      state.selectedSliceName = name || null;
      syncSelectedSlice(false);
    }

    function refreshBuilderStatus() {
      const status = document.getElementById("builderStatus");
      const saveBtn = document.getElementById("saveBtn");
      const cancelBtn = document.getElementById("cancelEditBtn");
      const nameInput = document.getElementById("slice_name");

      if (state.editingSliceName) {
        status.innerHTML = `<strong>Modo:</strong> editando <strong>${CloudUI.escapeHtml(state.editingSliceName)}</strong> (se recreará el slice)`;
        saveBtn.textContent = "Guardar cambios";
        cancelBtn.style.display = "";
        nameInput.readOnly = true;
      } else {
        status.innerHTML = `<strong>Modo:</strong> crear nuevo slice`;
        saveBtn.textContent = "Crear graph slice";
        cancelBtn.style.display = "none";
        nameInput.readOnly = false;
      }
    }

    function addNode(node = {}) {
      state.nodes.push({
        name: node.name || `n${state.nodes.length + 1}`,
        image_name: node.image_name || "cirros-base.img",
        vcpus: Number(node.vcpus || 1),
        ram_mb: Number(node.ram_mb || 256),
        disk_gb: Number(node.disk_gb || 10),
        preferred_worker: node.preferred_worker || "",
        internet: Boolean(node.internet || false)
      });
      renderNodes();
      renderLinks();
      renderPreview();
    }

    function updateNode(index, key, value) {
      if (key === "vcpus" || key === "ram_mb" || key === "disk_gb") value = Number(value);
      if (key === "internet") value = Boolean(value);
      state.nodes[index][key] = value;
      renderNodes();
      renderLinks();
      renderPreview();
    }

    function removeNode(index) {
      const removedName = state.nodes[index]?.name;
      state.nodes.splice(index, 1);
      state.links = state.links.filter(l => l.from !== removedName && l.to !== removedName);
      renderNodes();
      renderLinks();
      renderPreview();
    }

    function addLink(link = {}) {
      const names = state.nodes.map(n => n.name).filter(Boolean);
      state.links.push({
        id: link.id || `l${state.links.length + 1}`,
        from: link.from || names[0] || "",
        to: link.to || names[1] || names[0] || ""
      });
      renderLinks();
      renderPreview();
    }

    function updateLink(index, key, value) {
      state.links[index][key] = value;
      renderPreview();
    }

    function removeLink(index) {
      state.links.splice(index, 1);
      renderLinks();
      renderPreview();
    }

    function renderNodes() {
      const body = document.getElementById("nodesBody");
      body.innerHTML = state.nodes.map((node, i) => `
        <tr>
          <td><input value="${escapeAttr(node.name)}" oninput="updateNode(${i}, 'name', this.value)"></td>
          <td>
            <select onchange="updateNode(${i}, 'image_name', this.value)">
              ${images.map(img => `<option value="${img}" ${img === node.image_name ? "selected" : ""}>${img}</option>`).join("")}
            </select>
          </td>
          <td><input type="number" min="1" max="8" value="${node.vcpus}" oninput="updateNode(${i}, 'vcpus', this.value)"></td>
          <td><input type="number" min="128" max="32768" value="${node.ram_mb}" oninput="updateNode(${i}, 'ram_mb', this.value)"></td>
          <td><input type="number" min="2" max="200" value="${node.disk_gb}" oninput="updateNode(${i}, 'disk_gb', this.value)"></td>
          <td>
            <select onchange="updateNode(${i}, 'preferred_worker', this.value)">
              ${workers.map(w => `<option value="${w}" ${w === node.preferred_worker ? "selected" : ""}>${w || "auto"}</option>`).join("")}
            </select>
          </td>
          <td><input type="checkbox" ${node.internet ? "checked" : ""} onchange="updateNode(${i}, 'internet', this.checked)"></td>
          <td><button class="btn-danger btn-small" onclick="removeNode(${i})">Eliminar</button></td>
        </tr>
      `).join("");
    }

    function renderLinks() {
      const body = document.getElementById("linksBody");
      const names = state.nodes.map(n => n.name).filter(Boolean);
      body.innerHTML = state.links.map((link, i) => `
        <tr>
          <td><input value="${escapeAttr(link.id)}" oninput="updateLink(${i}, 'id', this.value)"></td>
          <td>
            <select onchange="updateLink(${i}, 'from', this.value)">
              ${names.map(n => `<option value="${n}" ${n === link.from ? "selected" : ""}>${n}</option>`).join("")}
            </select>
          </td>
          <td>
            <select onchange="updateLink(${i}, 'to', this.value)">
              ${names.map(n => `<option value="${n}" ${n === link.to ? "selected" : ""}>${n}</option>`).join("")}
            </select>
          </td>
          <td><button class="btn-danger btn-small" onclick="removeLink(${i})">Eliminar</button></td>
        </tr>
      `).join("");
    }

    function buildTopologySvg(nodes, links, options = {}) {
      if (!nodes.length) {
        return `<div class="svg-empty">Sin nodos.</div>`;
      }

      const width = options.width || 760;
      const height = options.height || 340;
      const cx = width / 2;
      const cy = height / 2;
      const radius = Math.min(width, height) * 0.33;
      const points = {};
      const interactive = Boolean(options.interactive);
      const sliceName = options.sliceName || "";

      nodes.forEach((node, idx) => {
        const angle = (Math.PI * 2 * idx / nodes.length) - Math.PI / 2;
        points[node.name] = {
          x: cx + Math.cos(angle) * radius,
          y: cy + Math.sin(angle) * radius
        };
      });

      const lines = links.map(link => {
        const a = points[link.from];
        const b = points[link.to];
        if (!a || !b) return "";
        const mx = (a.x + b.x) / 2;
        const my = (a.y + b.y) / 2;
        return `
          <line x1="${a.x}" y1="${a.y}" x2="${b.x}" y2="${b.y}" stroke="#f4b740" stroke-width="3" stroke-linecap="round"/>
          <rect x="${mx - 18}" y="${my - 18}" width="36" height="18" rx="9" fill="#0b132c" stroke="rgba(255,255,255,.08)"></rect>
          <text x="${mx}" y="${my - 5}" fill="#ffd980" font-size="11" font-weight="700" text-anchor="middle">${CloudUI.escapeHtml(link.id || "")}</text>
        `;
      }).join("");

      const devices = nodes.map(node => {
        const p = points[node.name];
        const isGateway = !!node.internet;
        const status = normalizeVmStatus(node);

        const border = isGateway ? "#f4b740" : "#7aa3ff";
        const bodyFill = status === "running" ? "#112246" : "#0d1530";
        const statusColor =
          status === "running" ? "#1fc97c" :
          status === "error" ? "#ff6177" :
          status === "planned" ? "#f4b740" :
          "#9eb0d4";

        const clickOpen = interactive
          ? `onclick="openVmDetailByName(${JSON.stringify(sliceName)}, ${JSON.stringify(node.name)}, event)"`
          : "";

        const actions = interactive ? [
          { action: "start",  label: "⏻", fill: "#1f7a4a", dx: -40, title: "Encender"  },
          { action: "stop",   label: "⏹", fill: "#8a2f3b", dx: -20, title: "Apagar"    },
          { action: "reboot", label: "↻", fill: "#355fb3", dx:   0, title: "Reiniciar" },
          { action: "pause",  label: "⏸", fill: "#4e5c86", dx:  20, title: "Pausar"    },
          { action: "resume", label: "▶", fill: "#4e5c86", dx:  40, title: "Reanudar"  }
        ].map(a => `
          <g class="svg-action-bubble"
             onclick="performVmActionInline(${JSON.stringify(a.action)}, ${JSON.stringify(sliceName)}, ${JSON.stringify(node.name)}, event)">
            <title>${a.title}</title>
            <circle cx="${p.x + a.dx}" cy="${p.y + 50}" r="9" fill="${a.fill}" stroke="rgba(255,255,255,.14)"></circle>
            <text x="${p.x + a.dx}" y="${p.y + 50}" class="svg-action-text">${a.label}</text>
          </g>
        `).join("") : "";

        const iconSvg = isGateway
          ? `
            <rect x="${p.x - 22}" y="${p.y - 10}" width="44" height="20" rx="6" fill="#071126" stroke="rgba(255,255,255,.16)"></rect>
            <circle cx="${p.x - 10}" cy="${p.y}" r="2.2" fill="#f4b740"></circle>
            <circle cx="${p.x}" cy="${p.y}" r="2.2" fill="#7aa3ff"></circle>
            <circle cx="${p.x + 10}" cy="${p.y}" r="2.2" fill="#1fc97c"></circle>
            <line x1="${p.x - 14}" y1="${p.y - 10}" x2="${p.x - 20}" y2="${p.y - 22}" stroke="#dce7ff" stroke-width="2" stroke-linecap="round"></line>
            <line x1="${p.x + 14}" y1="${p.y - 10}" x2="${p.x + 20}" y2="${p.y - 22}" stroke="#dce7ff" stroke-width="2" stroke-linecap="round"></line>
            <path d="M ${p.x - 24} ${p.y - 24} Q ${p.x} ${p.y - 40} ${p.x + 24} ${p.y - 24}" fill="none" stroke="rgba(244,183,64,.55)" stroke-width="2" stroke-linecap="round"></path>
          `
          : `
            <rect x="${p.x - 28}" y="${p.y - 18}" width="56" height="34" rx="8" fill="#071126" stroke="rgba(255,255,255,.16)"></rect>
            <rect x="${p.x - 21}" y="${p.y - 12}" width="42" height="22" rx="4" fill="rgba(122,163,255,.10)" stroke="rgba(122,163,255,.18)"></rect>
            <rect x="${p.x - 7}" y="${p.y + 17}" width="14" height="4" rx="2" fill="rgba(255,255,255,.30)"></rect>
            <rect x="${p.x - 16}" y="${p.y + 21}" width="32" height="4" rx="2" fill="rgba(255,255,255,.18)"></rect>
          `;

        return `
          <g class="${interactive ? 'svg-node-click' : ''}">
            <g ${clickOpen}>
              <rect x="${p.x - 48}" y="${p.y - 32}" width="96" height="64" rx="20" fill="${bodyFill}" stroke="${border}" stroke-width="2"></rect>
              ${iconSvg}
              <circle cx="${p.x - 35}" cy="${p.y - 22}" r="6" fill="${statusColor}"></circle>
              <text x="${p.x}" y="${p.y + 38}" fill="#dce7ff" font-size="13" font-weight="800" text-anchor="middle">${CloudUI.escapeHtml(node.name)}</text>
            </g>
            ${actions}
          </g>
        `;
      }).join("");

      return `<svg viewBox="0 0 ${width} ${height}" width="100%" height="${height}">${lines}${devices}</svg>`;
    }

    function renderPreview() {
      document.getElementById("previewWrap").innerHTML = buildTopologySvg(
        state.nodes.map(n => ({ ...n, status: "planned" })),
        state.links,
        { width: 760, height: 320 }
      );
    }

    function collectPayload() {
      return {
        slice_name: document.getElementById("slice_name").value.trim(),
        vlan_base: Number(document.getElementById("vlan_base").value),
        vnc_start: Number(document.getElementById("vnc_start").value),
        network_backend: document.getElementById("network_backend").value,
        internet_mode: document.getElementById("internet_mode").value,
        nodes: state.nodes.map(n => ({
          name: n.name.trim(),
          image_name: n.image_name,
          vcpus: Number(n.vcpus),
          ram_mb: Number(n.ram_mb),
          disk_gb: Number(n.disk_gb),
          ...(n.preferred_worker ? { preferred_worker: n.preferred_worker } : {}),
          internet: Boolean(n.internet)
        })),
        links: state.links.map(l => ({
          id: l.id.trim(),
          from: l.from,
          to: l.to
        }))
      };
    }

    function validatePayload(payload) {
      if (!payload.slice_name) throw new Error("Falta slice_name");
      if (payload.nodes.length < 2) throw new Error("Debes tener al menos 2 nodos");
      if (payload.links.length < 1) throw new Error("Debes tener al menos 1 enlace");

      const names = payload.nodes.map(n => n.name);
      const unique = new Set(names);
      if (unique.size !== names.length) throw new Error("Los nombres de nodos deben ser únicos");

      if (payload.internet_mode === "headnode_nat" && !payload.nodes.some(n => n.internet)) {
        throw new Error("Con headnode_nat al menos un nodo debe tener internet=true");
      }
    }

    async function saveGraphSlice() {
      try {
        const payload = collectPayload();
        validatePayload(payload);

        let data;
        if (state.editingSliceName) {
          data = await CloudUI.api(`/api/graph-slices/${encodeURIComponent(state.editingSliceName)}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          state.selectedSliceName = payload.slice_name;
        } else {
          data = await CloudUI.api("/api/graph-slices", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          state.selectedSliceName = payload.slice_name;
        }

        CloudUI.showResponse("output", data);
        cancelEdit(false);
        await loadGraphSlices();
      } catch (err) {
        CloudUI.showResponse("output", { error: String(err) });
      }
    }

    function startEdit(sliceName) {
      const slice = getSliceByName(sliceName);
      if (!slice) return;

      state.selectedSliceName = slice.slice_name;
      state.editingSliceName = slice.slice_name;

      document.getElementById("slice_name").value = slice.slice_name;
      document.getElementById("vlan_base").value = slice.vlan_base ?? 350;
      document.getElementById("vnc_start").value = (slice.vms && slice.vms.length) ? slice.vms[0].vnc_port : 6031;
      document.getElementById("network_backend").value = slice.network_backend || "vlan";
      document.getElementById("internet_mode").value = slice.internet_mode || "none";

      const sourceNodes = (slice.nodes && slice.nodes.length)
        ? slice.nodes
        : (slice.vms || []).map(vm => ({
            name: vm.name,
            image_name: vm.image_name || "cirros-base.img",
            vcpus: vm.vcpus || 1,
            ram_mb: vm.ram_mb || 256,
            disk_gb: vm.disk_gb || 10,
            preferred_worker: vm.preferred_worker || vm.server || "",
            internet: !!vm.internet
          }));

      state.nodes = sourceNodes.map(n => ({
        name: n.name,
        image_name: n.image_name || "cirros-base.img",
        vcpus: Number(n.vcpus || 1),
        ram_mb: Number(n.ram_mb || 256),
        disk_gb: Number(n.disk_gb || 10),
        preferred_worker: n.preferred_worker || "",
        internet: Boolean(n.internet || false)
      }));

      state.links = (slice.links || []).map(l => ({
        id: l.id,
        from: l.from,
        to: l.to
      }));

      refreshBuilderStatus();
      renderNodes();
      renderLinks();
      renderPreview();
      syncSelectedSlice(false);
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function editSelectedSlice() {
      const slice = getSelectedSlice();
      if (!slice) return;
      startEdit(slice.slice_name);
    }

    function cancelEdit(doReset = true) {
      state.editingSliceName = null;
      refreshBuilderStatus();
      if (doReset) resetBuilder();
    }

    async function deleteGraphSlice(name) {
      try {
        if (!confirm(`¿Eliminar graph slice ${name}?`)) return;
        const data = await CloudUI.api(`/api/graph-slices/${encodeURIComponent(name)}`, {
          method: "DELETE"
        });
        CloudUI.showResponse("output", data);
        if (state.editingSliceName === name) cancelEdit();
        if (state.selectedSliceName === name) state.selectedSliceName = null;
        await loadGraphSlices();
      } catch (err) {
        CloudUI.showResponse("output", { error: String(err) });
      }
    }

    function renderSliceSelector() {
      const selector = document.getElementById("sliceSelector");
      if (!state.graphSlices.length) {
        selector.innerHTML = `<option value="">Sin graph slices</option>`;
        selector.disabled = true;
        return;
      }

      selector.disabled = false;
      selector.innerHTML = state.graphSlices.map(slice => `
        <option value="${escapeAttr(slice.slice_name)}" ${slice.slice_name === state.selectedSliceName ? "selected" : ""}>
          ${CloudUI.escapeHtml(slice.slice_name)}
        </option>
      `).join("");
    }

    function inferPrimaryLinkInterface(vm) {
      return (vm.interfaces || []).find(i => i.link_id !== "nat") || (vm.interfaces || [])[0] || null;
    }

    function inferNatInterface(vm) {
      return (vm.interfaces || []).find(i => i.link_id === "nat") || null;
    }

    function formatIfaceAddress(iface) {
      if (!iface) return "-";
      return iface.ip_cidr || iface.dhcp_reservation_ip || "-";
    }

    function formatIfaceMode(iface) {
      if (!iface) return "-";
      if (iface.ip_cidr) return "estática";
      if (iface.dhcp_reservation_ip) return "dhcp";
      return "-";
    }

    function renderSelectedSliceView() {
      const slice = getSelectedSlice();
      const summary = document.getElementById("selectedSliceSummary");
      const topo = document.getElementById("selectedSliceTopology");
      const nodesWrap = document.getElementById("selectedSliceNodes");

      if (!slice) {
        summary.innerHTML = `
          <div class="summary-card"><h4>Slice</h4><strong>0</strong><span>Sin selección</span></div>
          <div class="summary-card"><h4>VMs</h4><strong>0</strong><span>Sin datos</span></div>
          <div class="summary-card"><h4>Running</h4><strong>0</strong><span>Sin datos</span></div>
          <div class="summary-card"><h4>Internet</h4><strong>0</strong><span>Sin datos</span></div>
        `;
        topo.innerHTML = `<div class="svg-empty">Selecciona un slice para ver su topología real.</div>`;
        nodesWrap.innerHTML = `<div class="empty">No hay VMs para mostrar.</div>`;
        return;
      }

      const vms = slice.vms || [];
      const running = vms.filter(vm => (vm.status || "").toLowerCase() === "running").length;
      const gateways = vms.filter(vm => !!vm.internet).length;
      const backend = slice.network_backend || "-";
      const internetMode = slice.internet_mode || "-";

      summary.innerHTML = `
        <div class="summary-card">
          <h4>Slice</h4>
          <strong>${CloudUI.escapeHtml(slice.slice_name)}</strong>
          <span>backend=${CloudUI.escapeHtml(backend)}</span>
        </div>
        <div class="summary-card">
          <h4>VMs</h4>
          <strong>${vms.length}</strong>
          <span>${(slice.links || []).length} enlace(s)</span>
        </div>
        <div class="summary-card">
          <h4>Running</h4>
          <strong>${running}</strong>
          <span>${vms.length - running} restante(s)</span>
        </div>
        <div class="summary-card">
          <h4>Internet</h4>
          <strong>${gateways}</strong>
          <span>${CloudUI.escapeHtml(internetMode)}</span>
        </div>
      `;

      topo.innerHTML = buildTopologySvg(vms.length ? vms : (slice.nodes || []), slice.links || [], { width: 760, height: 340 });

      const sliceIndex = state.graphSlices.findIndex(s => s.slice_name === slice.slice_name);
      if (!vms.length) {
        nodesWrap.innerHTML = `<div class="empty">Este slice no tiene VMs reportadas.</div>`;
        return;
      }

      nodesWrap.innerHTML = vms.map((vm, vmIndex) => {
        const primary = inferPrimaryLinkInterface(vm);
        const natIface = inferNatInterface(vm);
        const gatewayBadge = vm.internet ? `<span class="node-role-badge gateway">gateway</span>` : `<span class="node-role-badge vm">vm</span>`;
        const icon = vm.internet ? "🌐" : "🖥️";
        return `
          <div class="slice-node-card" onclick="openVmDetail(${sliceIndex}, ${vmIndex})">
            <div class="slice-node-head">
              <div style="display:flex;align-items:center;gap:10px">
                <div class="device-icon">${icon}</div>
                <div>
                  <strong>${CloudUI.escapeHtml(vm.name)}</strong>
                  <div class="vm-box-sub">${CloudUI.escapeHtml(vm.image_name || "-")}</div>
                </div>
              </div>
              ${gatewayBadge}
            </div>

            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
              ${statusPillHtml(vm.status)}
              <span class="tag">worker=${CloudUI.escapeHtml(vm.server || "-")}</span>
            </div>

            <div class="node-meta-grid">
              <div>IP principal</div><div>${CloudUI.escapeHtml(formatIfaceAddress(primary))}</div>
              <div>Modo red</div><div>${CloudUI.escapeHtml(formatIfaceMode(primary))}</div>
              <div>NAT / Internet</div><div>${CloudUI.escapeHtml(formatIfaceAddress(natIface))}</div>
              <div>vCPU / RAM</div><div>${CloudUI.escapeHtml(String(vm.vcpus || "-"))} / ${CloudUI.escapeHtml(String(vm.ram_mb || "-"))} MB</div>
              <div>Disco</div><div>${CloudUI.escapeHtml(String(vm.disk_gb || "-"))} GB</div>
              <div>VNC</div><div>${CloudUI.escapeHtml(String(vm.vnc_port || "-"))}</div>
            </div>

            <div class="quick-actions-inline">
              <button class="btn-success btn-small icon-action-btn" title="Encender" aria-label="Encender" onclick="performVmActionInline('start', ${JSON.stringify(slice.slice_name)}, ${JSON.stringify(vm.name)}, event)">⏻</button>
              <button class="btn-danger btn-small icon-action-btn" title="Apagar" aria-label="Apagar" onclick="performVmActionInline('stop', ${JSON.stringify(slice.slice_name)}, ${JSON.stringify(vm.name)}, event)">⏹</button>
              <button class="btn-secondary btn-small icon-action-btn" title="Reiniciar" aria-label="Reiniciar" onclick="performVmActionInline('reboot', ${JSON.stringify(slice.slice_name)}, ${JSON.stringify(vm.name)}, event)">↻</button>
              <button class="btn-secondary btn-small icon-action-btn" title="Pausar" aria-label="Pausar" onclick="performVmActionInline('pause', ${JSON.stringify(slice.slice_name)}, ${JSON.stringify(vm.name)}, event)">⏸</button>
              <button class="btn-secondary btn-small icon-action-btn" title="Reanudar" aria-label="Reanudar" onclick="performVmActionInline('resume', ${JSON.stringify(slice.slice_name)}, ${JSON.stringify(vm.name)}, event)">▶</button>
            </div>
          </div>
        `;
