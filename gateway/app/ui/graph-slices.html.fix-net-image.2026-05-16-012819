    function clearTerminal() {
      if (terminalInstance) terminalInstance.clear();
    }

    function buildWsUrl(worker) {
      const scheme = window.location.protocol === "https:" ? "wss" : "ws";
      const token = encodeURIComponent(CloudUI.getToken());
      return `${scheme}://${window.location.host}/ws/worker-shell?worker=${encodeURIComponent(worker)}&token=${token}`;
    }

    function openWorkerTerminal() {
      if (!state.selectedVm) return;
      const vm = state.selectedVm.vm;

      document.getElementById("terminalModal").classList.add("show");
      document.getElementById("terminalTitle").textContent = `Terminal worker · ${vm.name}`;
      document.getElementById("terminalStatus").textContent = `Conectando a ${vm.server}...`;

      destroyTerminal();

      const mount = document.getElementById("terminalMount");
      terminalInstance = new Terminal({
        cursorBlink: true,
        fontSize: 13,
        convertEol: true,
        theme: { background: "#050b18", foreground: "#e5edff" }
      });

      fitAddon = new FitAddon.FitAddon();
      terminalInstance.loadAddon(fitAddon);
      terminalInstance.open(mount);
      fitAddon.fit();
      terminalInstance.focus();
      terminalInstance.writeln("[PUCP Cloud] Abriendo terminal del worker...");
      terminalInstance.writeln(`[PUCP Cloud] VM: ${vm.name} | worker: ${vm.server}`);
      terminalInstance.writeln("");

      terminalSocket = new WebSocket(buildWsUrl(vm.server));

      terminalSocket.onopen = () => {
        document.getElementById("terminalStatus").textContent = `Conectada a ${vm.server}`;
        fitAddon.fit();
        terminalSocket.send(`__resize__:${terminalInstance.cols}:${terminalInstance.rows}`);
      };

      terminalSocket.onmessage = (event) => {
        if (terminalInstance) terminalInstance.write(event.data);
      };

      terminalSocket.onclose = () => {
        document.getElementById("terminalStatus").textContent = `Sesión cerrada`;
        if (terminalInstance) terminalInstance.writeln("\r\n[PUCP Cloud] Sesión finalizada.");
      };

      terminalSocket.onerror = () => {
        document.getElementById("terminalStatus").textContent = `Error de conexión`;
        if (terminalInstance) terminalInstance.writeln("\r\n[PUCP Cloud] Error en websocket.");
      };

      terminalInstance.onData((data) => {
        if (terminalSocket && terminalSocket.readyState === WebSocket.OPEN) {
          terminalSocket.send(data);
        }
      });

      terminalResizeHandler = () => {
        if (!terminalInstance || !fitAddon || !terminalSocket) return;
        fitAddon.fit();
        if (terminalSocket.readyState === WebSocket.OPEN) {
          terminalSocket.send(`__resize__:${terminalInstance.cols}:${terminalInstance.rows}`);
        }
      };

      window.addEventListener("resize", terminalResizeHandler);
    }

