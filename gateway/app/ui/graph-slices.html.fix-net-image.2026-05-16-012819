    function destroyTerminal() {
      if (terminalResizeHandler) {
        window.removeEventListener("resize", terminalResizeHandler);
        terminalResizeHandler = null;
      }
      if (terminalSocket) {
        try { terminalSocket.close(); } catch (_) {}
        terminalSocket = null;
      }
      if (terminalInstance) {
        try { terminalInstance.dispose(); } catch (_) {}
        terminalInstance = null;
      }
      fitAddon = null;
      document.getElementById("terminalMount").innerHTML = "";
      document.getElementById("terminalStatus").textContent = "Desconectada";
    }

