<!-- GRAPH_SLICES_UX_PATCH_V1 -->
<script>
(() => {
  if (window.__graphSlicesUxPatchInstalled) return;
  window.__graphSlicesUxPatchInstalled = true;

  const LS_KEY = "graphSlices.imageSelectionByNode";
  const state = {
    creating: false,
    createTimers: [],
    imageByNode: {}
  };

  try {
    state.imageByNode = JSON.parse(localStorage.getItem(LS_KEY) || "{}") || {};
  } catch (_) {
    state.imageByNode = {};
  }

  const IMAGE_RE = /\.(img|qcow2|iso|raw|vmdk)$/i;

  function saveImageMap() {
    localStorage.setItem(LS_KEY, JSON.stringify(state.imageByNode));
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function getButtonByText(regex) {
    return [...document.querySelectorAll("button")]
      .find(btn => regex.test((btn.textContent || "").trim()));
  }

  function findResponseCard() {
    const headers = [...document.querySelectorAll("h2,h3,h4,.panel-title,.card-title")];
    for (const el of headers) {
      const t = (el.textContent || "").trim().toLowerCase();
      if (t.includes("respuesta") || t.includes("estado del despliegue")) {
        return el.closest("section, .card, .panel, .widget, .builder-card, .response-card, div");
      }
    }
    return null;
  }

  function injectStyles() {
    if (document.getElementById("graph-slices-ux-style")) return;
    const style = document.createElement("style");
    style.id = "graph-slices-ux-style";
    style.textContent = `
      .deploy-ux-root{
        margin-top:12px;
        border:1px solid rgba(255,255,255,.07);
        border-radius:16px;
        background:linear-gradient(180deg, rgba(12,20,48,.92), rgba(9,16,38,.96));
        padding:14px;
      }
      .deploy-ux-top{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
        flex-wrap:wrap;
        margin-bottom:12px;
      }
      .deploy-ux-badge{
        display:inline-flex;
        align-items:center;
        gap:8px;
        padding:8px 12px;
        border-radius:999px;
        font-size:12px;
        font-weight:700;
        border:1px solid rgba(255,255,255,.08);
        background:#18264b;
        color:#dce7ff;
      }
      .deploy-ux-badge.ok{ color:#94f7ba; border-color:rgba(148,247,186,.25); }
      .deploy-ux-badge.run{ color:#8bc0ff; border-color:rgba(139,192,255,.25); }
      .deploy-ux-badge.err{ color:#ff99a5; border-color:rgba(255,153,165,.25); }
      .deploy-ux-time{
        color:var(--muted, #9fb1d9);
        font-size:12px;
      }
      .deploy-ux-progress{
        width:100%;
        height:8px;
        border-radius:999px;
        background:#162448;
        overflow:hidden;
        margin:8px 0 14px;
      }
      .deploy-ux-progress > span{
        display:block;
        height:100%;
        width:0%;
        background:linear-gradient(90deg,#6ea8ff,#58d1c9);
        transition:width .25s ease;
      }
      .deploy-ux-steps{
        display:grid;
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:10px;
        margin-bottom:14px;
      }
      .deploy-step{
        display:flex;
        align-items:center;
        gap:10px;
        padding:10px 12px;
        border-radius:12px;
        background:#101a39;
        border:1px solid rgba(255,255,255,.06);
        font-size:12px;
      }
      .deploy-step .dot{
        width:10px;
        height:10px;
        border-radius:50%;
        background:#5a6a96;
        flex:0 0 10px;
      }
      .deploy-step.pending .dot{ background:#5a6a96; }
      .deploy-step.running .dot{ background:#6ea8ff; box-shadow:0 0 0 4px rgba(110,168,255,.12); }
      .deploy-step.ok .dot{ background:#52d6a3; }
      .deploy-step.err .dot{ background:#ff6b81; }
      .deploy-ux-logs-wrap{
        margin-top:8px;
      }
      .deploy-ux-logs-title{
        font-size:12px;
        color:var(--muted, #9fb1d9);
        text-transform:uppercase;
        letter-spacing:.04em;
        margin-bottom:8px;
      }
      .deploy-ux-logs{
        min-height:160px;
        max-height:300px;
        overflow:auto;
        border-radius:14px;
        background:#081129;
        border:1px solid rgba(255,255,255,.06);
        padding:12px;
        font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;
        font-size:12px;
        line-height:1.55;
        white-space:pre-wrap;
      }
      .deploy-log-line{ margin:0 0 4px; }
      .deploy-log-info{ color:#d7e6ff; }
      .deploy-log-ok{ color:#97f3bf; }
      .deploy-log-err{ color:#ff9aa5; }
      .deploy-ux-summary{
        margin-top:12px;
        display:none;
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:10px;
      }
      .deploy-ux-summary.active{ display:grid; }
      .deploy-summary-item{
        padding:10px 12px;
        border-radius:12px;
        background:#101a39;
        border:1px solid rgba(255,255,255,.06);
        font-size:12px;
      }
      .deploy-summary-item strong{
        display:block;
        color:#fff;
        margin-bottom:4px;
        font-size:14px;
      }
      .deploy-ux-raw{
        margin-top:12px;
      }
      .deploy-ux-raw summary{
        cursor:pointer;
        color:var(--muted, #9fb1d9);
        font-size:12px;
        margin-bottom:8px;
      }
      .deploy-ux-raw pre{
        white-space:pre-wrap;
        max-height:220px;
        overflow:auto;
        background:#081129;
        border:1px solid rgba(255,255,255,.06);
        border-radius:12px;
        padding:12px;
        font-size:12px;
      }
      .btn-creating{
        opacity:.88;
        cursor:not-allowed !important;
        pointer-events:none !important;
      }
      .btn-creating::after{
        content:"";
        display:inline-block;
        width:12px;
        height:12px;
        margin-left:8px;
        border:2px solid rgba(255,255,255,.5);
        border-top-color:#fff;
        border-radius:50%;
        animation:spinDeployBtn .8s linear infinite;
        vertical-align:-2px;
      }
      @keyframes spinDeployBtn{
        to{ transform:rotate(360deg); }
      }
      @media (max-width:900px){
        .deploy-ux-steps,
        .deploy-ux-summary{
          grid-template-columns:1fr;
        }
      }
    `;
    document.head.appendChild(style);
  }

  function ensureDeployUI() {
    injectStyles();
    const card = findResponseCard();
    if (!card) return null;

    const title = [...card.querySelectorAll("h2,h3,h4,.panel-title,.card-title")]
      .find(el => /respuesta|estado del despliegue/i.test((el.textContent || "").trim()));
    if (title) title.textContent = "Estado del despliegue";

    const subtitle = [...card.querySelectorAll("p,small,span")]
      .find(el => /salida del backend|backend/i.test((el.textContent || "").trim()));
    if (subtitle) subtitle.textContent = "Logs visuales, progreso y respuesta técnica";

    let root = card.querySelector("#deploy-ux-root");
    if (root) return root;

    root = document.createElement("div");
    root.id = "deploy-ux-root";
    root.className = "deploy-ux-root";
    root.innerHTML = `
      <div class="deploy-ux-top">
        <div class="deploy-ux-badge" id="deployStatusBadge">Listo</div>
        <div class="deploy-ux-time" id="deployStatusTime">sin actividad</div>
      </div>
      <div class="deploy-ux-progress"><span id="deployProgressBar"></span></div>

      <div class="deploy-ux-steps">
        <div class="deploy-step pending" data-step="validate"><span class="dot"></span><span>Validación</span></div>
        <div class="deploy-step pending" data-step="prepare"><span class="dot"></span><span>Preparación</span></div>
        <div class="deploy-step pending" data-step="deploy"><span class="dot"></span><span>Despliegue de VMs</span></div>
        <div class="deploy-step pending" data-step="finalize"><span class="dot"></span><span>Verificación final</span></div>
      </div>

      <div class="deploy-ux-logs-wrap">
        <div class="deploy-ux-logs-title">Logs</div>
        <div class="deploy-ux-logs" id="deployLogs"></div>
      </div>

      <div class="deploy-ux-summary" id="deploySummary"></div>

      <details class="deploy-ux-raw">
        <summary>Respuesta técnica del backend</summary>
        <pre id="deployRawResponse">(vacío)</pre>
      </details>
    `;

    const anchor = card.querySelector("pre, code, textarea");
    if (anchor && anchor.parentNode) {
      anchor.parentNode.insertBefore(root, anchor);
    } else {
      card.appendChild(root);
    }

    return root;
  }

  function nowTime() {
    const d = new Date();
    return d.toLocaleTimeString();
  }

  function setBadge(text, cls = "") {
    const root = ensureDeployUI();
    if (!root) return;
    const badge = root.querySelector("#deployStatusBadge");
    badge.textContent = text;
    badge.className = "deploy-ux-badge " + cls;
  }

  function setTime(text) {
    const root = ensureDeployUI();
    if (!root) return;
    root.querySelector("#deployStatusTime").textContent = text;
  }

  function setProgress(percent) {
    const root = ensureDeployUI();
    if (!root) return;
    root.querySelector("#deployProgressBar").style.width = Math.max(0, Math.min(100, percent)) + "%";
  }

  function setStep(step, status) {
    const root = ensureDeployUI();
    if (!root) return;
    const el = root.querySelector(`.deploy-step[data-step="${step}"]`);
    if (!el) return;
    el.className = `deploy-step ${status}`;
  }

  function resetSteps() {
    ["validate", "prepare", "deploy", "finalize"].forEach(s => setStep(s, "pending"));
  }

  function clearLogs() {
    const root = ensureDeployUI();
    if (!root) return;
    root.querySelector("#deployLogs").innerHTML = "";
    root.querySelector("#deployRawResponse").textContent = "(vacío)";
    const sum = root.querySelector("#deploySummary");
    sum.innerHTML = "";
    sum.classList.remove("active");
  }

  function appendLog(msg, kind = "info") {
    const root = ensureDeployUI();
    if (!root) return;
    const box = root.querySelector("#deployLogs");
    const line = document.createElement("div");
    line.className = `deploy-log-line deploy-log-${kind}`;
    line.textContent = `[${nowTime()}] ${msg}`;
    box.appendChild(line);
    box.scrollTop = box.scrollHeight;
  }

  function setRawResponse(text) {
    const root = ensureDeployUI();
    if (!root) return;
    root.querySelector("#deployRawResponse").textContent = text || "(vacío)";
  }

  function setSummary(items) {
    const root = ensureDeployUI();
    if (!root) return;
    const box = root.querySelector("#deploySummary");
    const html = (items || []).map(item => `
      <div class="deploy-summary-item">
        <strong>${escapeHtml(item.label)}</strong>
        <div>${escapeHtml(item.value)}</div>
      </div>
    `).join("");
    box.innerHTML = html;
    if (html) box.classList.add("active");
    else box.classList.remove("active");
  }

  function findCreateButton() {
    return getButtonByText(/crear graph slice/i);
  }

  function setCreateButtonState(creating) {
    const btn = findCreateButton();
    if (!btn) return;
    if (!btn.dataset.originalText) {
      btn.dataset.originalText = btn.textContent.trim();
    }
    if (creating) {
      btn.disabled = true;
      btn.classList.add("btn-creating");
      btn.textContent = "Creando...";
    } else {
      btn.disabled = false;
      btn.classList.remove("btn-creating");
      btn.textContent = btn.dataset.originalText || "Crear graph slice";
    }
  }

  function clearTimers() {
    state.createTimers.forEach(t => clearTimeout(t));
    state.createTimers = [];
  }

  function simulatePhases() {
    clearTimers();
    resetSteps();
    setBadge("Validando", "run");
    setTime("iniciando despliegue...");
    setProgress(8);
    appendLog("Validando topología y nombre del slice...");
    setStep("validate", "running");

    state.createTimers.push(setTimeout(() => {
      setStep("validate", "ok");
      setStep("prepare", "running");
      setBadge("Preparando", "run");
      setProgress(28);
      appendLog("Preparando payload y verificando imágenes...");
    }, 800));

    state.createTimers.push(setTimeout(() => {
      setStep("prepare", "ok");
      setStep("deploy", "running");
      setBadge("Desplegando", "run");
      setProgress(58);
      appendLog("Enviando solicitud al backend y desplegando VMs...");
    }, 1800));

    state.createTimers.push(setTimeout(() => {
      setStep("deploy", "running");
      setStep("finalize", "running");
      setBadge("Verificando", "run");
      setProgress(82);
      appendLog("Aplicando verificación final y refrescando vista...");
    }, 3200));
  }

  function summarizeResponse(obj) {
    const items = [];
    if (!obj || typeof obj !== "object") return items;

    if (obj.slice_name) items.push({ label: "Slice", value: obj.slice_name });
    if (obj.name) items.push({ label: "Nombre", value: obj.name });
    if (obj.network_backend) items.push({ label: "Backend", value: obj.network_backend });
    if (obj.internet_mode) items.push({ label: "Internet", value: obj.internet_mode });
    if (Array.isArray(obj.vms)) items.push({ label: "VMs", value: String(obj.vms.length) });
    if (Array.isArray(obj.nodes)) items.push({ label: "Nodos", value: String(obj.nodes.length) });
    if (Array.isArray(obj.links)) items.push({ label: "Enlaces", value: String(obj.links.length) });

    return items;
  }

  function extractErrorMessage(payloadText, parsed) {
    if (parsed && typeof parsed === "object") {
      return parsed.error || parsed.detail || parsed.message || JSON.stringify(parsed);
    }
    return payloadText || "Error desconocido";
  }

  function syncNodeState(nodeName, value) {
    try {
      if (window.state && Array.isArray(window.state.nodes)) {
        const n = window.state.nodes.find(x => (x.name || "").trim() === nodeName);
        if (n) {
          n.image_name = value;
          n.image = value;
          n.imageName = value;
        }
      }
    } catch (_) {}
  }

  function optionLooksLikeImage(opt) {
    const txt = `${opt.value || ""} ${opt.textContent || ""}`;
    return IMAGE_RE.test(txt);
  }

  function selectLooksLikeImageSelect(sel) {
    const opts = [...sel.options];
    return opts.some(optionLooksLikeImage);
  }

  function getNodeNameFromRow(row) {
    if (!row) return "";
    const textInputs = [...row.querySelectorAll('input[type="text"]')];
    const named = textInputs.find(i => {
      const ph = (i.getAttribute("placeholder") || "").toLowerCase();
      const nm = (i.name || "").toLowerCase();
      return ph.includes("nombre") || nm.includes("name") || nm.includes("nombre");
    });
    const fallback = named || textInputs[0];
    return (fallback?.value || "").trim();
  }

  function captureImageSelection(selectEl) {
    if (!selectEl || !selectLooksLikeImageSelect(selectEl)) return;
    const row = selectEl.closest("tr, .node-row, .builder-row, .grid-row, .row, .table-row");
    const nodeName = getNodeNameFromRow(row);
    const opt = selectEl.options[selectEl.selectedIndex];
    const value = selectEl.value || opt?.value || opt?.textContent?.trim();
    const text = opt?.textContent?.trim() || value;
    if (!nodeName || !value) return;

    state.imageByNode[nodeName] = { value, text };
    saveImageMap();
    syncNodeState(nodeName, value);
    appendLog(`Imagen seleccionada para ${nodeName}: ${text}`, "info");
  }

  function restoreImageSelections() {
    const selects = [...document.querySelectorAll("select")].filter(selectLooksLikeImageSelect);
    for (const sel of selects) {
      const row = sel.closest("tr, .node-row, .builder-row, .grid-row, .row, .table-row");
      const nodeName = getNodeNameFromRow(row);
      if (!nodeName || !state.imageByNode[nodeName]) continue;
      const wanted = state.imageByNode[nodeName];
      const options = [...sel.options];

      let match = options.find(o => o.value === wanted.value);
      if (!match) {
        match = options.find(o => (o.textContent || "").trim() === wanted.text);
      }
      if (!match) continue;

      if (sel.value !== match.value) {
        sel.value = match.value;
        syncNodeState(nodeName, match.value);
      }
    }
  }

  const originalFetch = window.fetch.bind(window);
  window.fetch = async function(input, init) {
    const reqUrl = typeof input === "string" ? input : (input && input.url) || "";
    const reqMethod =
      ((init && init.method) ||
      (typeof input !== "string" && input && input.method) ||
      "GET").toUpperCase();

    const isCreateGraphSlice =
      reqMethod === "POST" && /\/api\/graph-slices(?:$|\?)/.test(reqUrl);

    if (!isCreateGraphSlice) {
      return originalFetch(input, init);
    }

    ensureDeployUI();
    state.creating = true;
    setCreateButtonState(true);
    clearLogs();
    simulatePhases();

    try {
      const response = await originalFetch(input, init);
      const cloned = response.clone();
      const text = await cloned.text();
      setRawResponse(text);

      let parsed = null;
      try { parsed = JSON.parse(text); } catch (_) {}

      if (response.ok) {
        setStep("deploy", "ok");
        setStep("finalize", "ok");
        setBadge("Desplegado", "ok");
        setTime("finalizado correctamente");
        setProgress(100);
        appendLog("Slice desplegado correctamente.", "ok");
        const summary = summarizeResponse(parsed);
        setSummary(summary);
      } else {
        setStep("finalize", "err");
        setBadge("Error", "err");
        setTime("falló el despliegue");
        setProgress(100);
        appendLog(extractErrorMessage(text, parsed), "err");
        const summary = summarizeResponse(parsed);
        setSummary(summary);
      }

      return response;
    } catch (err) {
      setStep("finalize", "err");
      setBadge("Error de red", "err");
      setTime("falló la solicitud");
      setProgress(100);
      appendLog(String(err), "err");
      throw err;
    } finally {
      state.creating = false;
      clearTimers();
      setCreateButtonState(false);
    }
  };

  document.addEventListener("click", (ev) => {
    const btn = ev.target.closest("button");
    if (!btn) return;
    if (/crear graph slice/i.test((btn.textContent || "").trim())) {
      ensureDeployUI();
    }
  });

  document.addEventListener("change", (ev) => {
    const target = ev.target;
    if (!(target instanceof HTMLSelectElement)) return;
    if (!selectLooksLikeImageSelect(target)) return;
    captureImageSelection(target);
  });

  const observer = new MutationObserver(() => {
    ensureDeployUI();
    restoreImageSelections();
  });

  if (document.body) {
    observer.observe(document.body, { childList: true, subtree: true });
  }

  ensureDeployUI();
  restoreImageSelections();
})();
</script>

