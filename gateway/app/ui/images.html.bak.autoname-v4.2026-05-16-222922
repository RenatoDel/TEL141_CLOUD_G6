<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <title>Imágenes · PUCP Private Cloud</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/static/app.css">
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-badge">☁</div>
        <div>
          <h2>PUCP Cloud</h2>
          <p>Módulos separados</p>
        </div>
      </div>
      <nav class="nav">
        <a href="/dashboard.html" data-nav="dashboard">Dashboard</a>
        <a href="/images.html" data-nav="images">Imágenes</a>
        <a href="/slices.html" data-nav="slices">Slices legacy</a>
        <a href="/graph-slices.html" data-nav="graph">Graph slices</a>
        <a href="/monitoring.html" data-nav="monitoring">Monitoreo</a>
      </nav>
      <div class="sidebar-bottom">
        <div class="user-pill">Sesión: <strong data-user-name>admin</strong></div>
        <button class="btn-danger logout-btn" data-logout>Cerrar sesión</button>
      </div>
    </aside>

    <main class="main">
      <div class="topbar">
        <div>
          <h1 class="page-title">Imágenes</h1>
          <p class="page-subtitle">Subida real, importación por URL y catálogo</p>
        </div>
        <div class="chips">
          <span class="chip ok">image_service</span>
          <span class="chip" id="countChip">0 imágenes</span>
        </div>
      </div>

      <div class="grid grid-2">
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Subir archivo</h2>
            <p class="card-subtitle">Carga una imagen real al catálogo</p>
          </div>
          <div class="card-body">
            <div class="form-grid">
              <div class="field">
                <label>Nombre lógico</label>
                <input id="upload_name" value="ubuntu-20.04-server-cloudimg-amd64.img">
              </div>
              <div class="field">
                <label>OS type</label>
                <select id="upload_os_type">
                  <option value="ubuntu" selected>ubuntu</option>
                  <option value="cirros">cirros</option>
                  <option value="linux">linux</option>
                </select>
              </div>
              <div class="field">
                <label>Formato</label>
                <select id="upload_format">
                  <option value="qcow2" selected>qcow2</option>
                  <option value="img">img</option>
                  <option value="raw">raw</option>
                  <option value="iso">iso</option>
                </select>
              </div>
              <div class="field">
                <label>Archivo</label>
                <input id="upload_file" type="file" accept=".img,.qcow2,.iso,.raw">
              </div>
            </div>

            <div class="toolbar" style="margin-top:16px">
              <button class="btn-primary" onclick="uploadImage()">Subir imagen</button>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Importar por URL</h2>
            <p class="card-subtitle">Descarga directa desde internet</p>
          </div>
          <div class="card-body">
            <div class="form-grid">
              <div class="field">
                <label>Nombre lógico</label>
                <input id="url_name" value="ubuntu-focal-from-url.img">
              </div>
              <div class="field">
                <label>OS type</label>
                <select id="url_os_type">
                  <option value="ubuntu" selected>ubuntu</option>
                  <option value="cirros">cirros</option>
                  <option value="linux">linux</option>
                </select>
              </div>
              <div class="field">
                <label>Formato</label>
                <select id="url_format">
                  <option value="qcow2" selected>qcow2</option>
                  <option value="img">img</option>
                  <option value="raw">raw</option>
                  <option value="iso">iso</option>
                </select>
              </div>
              <div class="field full">
                <label>URL</label>
                <input id="url_value" placeholder="https://.../ubuntu-20.04-server-cloudimg-amd64.img">
              </div>
            </div>

            <div class="toolbar" style="margin-top:16px">
              <button class="btn-secondary" onclick="importFromUrl()">Importar URL</button>
            </div>
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:20px">
        <div class="card-header">
          <h2 class="card-title">Respuesta</h2>
          <p class="card-subtitle">Resultado del backend</p>
        </div>
        <div class="card-body">
          <pre id="output">Esperando acción...</pre>
        </div>
      </div>

      <div class="card" style="margin-top:20px">
        <div class="card-header">
          <h2 class="card-title">Catálogo actual</h2>
          <p class="card-subtitle">Imágenes disponibles</p>
        </div>
        <div class="card-body">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Filename</th>
                  <th>OS</th>
                  <th>Formato</th>
                  <th>Tamaño GB</th>
                  <th>Origen</th>
                  <th>SHA256</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="imagesBody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="/static/app.js"></script>
  <script>
    CloudUI.requireAuth();
    CloudUI.setupLayout("images");

    function setCount(n) {
      const chip = document.getElementById("countChip");
      chip.textContent = `${n} imágenes`;
    }

    async function loadImages() {
      try {
        const data = await CloudUI.api("/api/images");
        const body = document.getElementById("imagesBody");
        setCount(data.length);

        body.innerHTML = data.map(img => `
          <tr>
            <td>${CloudUI.escapeHtml(img.name)}</td>
            <td>${CloudUI.escapeHtml(img.filename)}</td>
            <td>${CloudUI.escapeHtml(img.os_type)}</td>
            <td>${CloudUI.escapeHtml(img.format)}</td>
            <td>${CloudUI.escapeHtml(String(img.size_gb))}</td>
            <td>${CloudUI.escapeHtml(img.source || "-")}</td>
            <td style="max-width:180px;word-break:break-all">${CloudUI.escapeHtml(img.sha256 || "-")}</td>
            <td>
              <div class="toolbar">
                <button class="btn-secondary btn-small" onclick="downloadImage('${img.stored_filename || img.filename}')">Descargar</button>
                <button class="btn-danger btn-small" onclick="deleteImage('${img.name}')">Eliminar</button>
              </div>
            </td>
          </tr>
        `).join("");

        CloudUI.showResponse("output", data);
      } catch (err) {
        CloudUI.showResponse("output", { error: String(err) });
      }
    }

    async function uploadImage() {
      try {
        const fileInput = document.getElementById("upload_file");
        if (!fileInput.files.length) throw new Error("Selecciona un archivo");

        const fd = new FormData();
        fd.append("name", document.getElementById("upload_name").value.trim());
        fd.append("os_type", document.getElementById("upload_os_type").value);
        fd.append("format", document.getElementById("upload_format").value);
        fd.append("file", fileInput.files[0]);

        const res = await fetch("/api/images/upload", {
          method: "POST",
          headers: {
            Authorization: `Bearer ${CloudUI.getToken()}`
          },
          body: fd
        });

        const text = await res.text();
        let data;
        try { data = JSON.parse(text); } catch { data = text; }
        if (!res.ok) throw new Error(data.detail || JSON.stringify(data));

        CloudUI.showResponse("output", data);
        fileInput.value = "";
        await loadImages();
      } catch (err) {
        CloudUI.showResponse("output", { error: String(err) });
      }
    }

    async function importFromUrl() {
      try {
        const fd = new FormData();
        fd.append("name", document.getElementById("url_name").value.trim());
        fd.append("url", document.getElementById("url_value").value.trim());
        fd.append("os_type", document.getElementById("url_os_type").value);
        fd.append("format", document.getElementById("url_format").value);

        const res = await fetch("/api/images/import-url", {
          method: "POST",
          headers: {
            Authorization: `Bearer ${CloudUI.getToken()}`
          },
          body: fd
        });

        const text = await res.text();
        let data;
        try { data = JSON.parse(text); } catch { data = text; }
        if (!res.ok) throw new Error(data.detail || JSON.stringify(data));

        CloudUI.showResponse("output", data);
        await loadImages();
      } catch (err) {
        CloudUI.showResponse("output", { error: String(err) });
      }
    }

    function downloadImage(storedFilename) {
      window.open(`/api/images/download/${encodeURIComponent(storedFilename)}`, "_blank");
    }

    async function deleteImage(name) {
      try {
        if (!confirm(`¿Eliminar imagen ${name}?`)) return;
        const data = await CloudUI.api(`/api/images/${encodeURIComponent(name)}`, {
          method: "DELETE"
        });
        CloudUI.showResponse("output", data);
        await loadImages();
      } catch (err) {
        CloudUI.showResponse("output", { error: String(err) });
      }
    }

    loadImages();
  </script>


<!-- IMAGE_UPLOAD_AUTONAME_V3 -->
<script>
(() => {
  if (window.__imageAutoNameV3Installed) return;
  window.__imageAutoNameV3Installed = true;

  function splitBaseName(filename) {
    const justName = (filename || "").split(/[\\/]/).pop() || "";
    return justName.replace(/\.[^.]+$/, "").trim();
  }

  function normalizeKey(value) {
    return (value || "").trim().toLowerCase();
  }

  function looksReplaceable(current, seed, lastAuto) {
    const c = (current || "").trim();
    const s = (seed || "").trim();
    const a = (lastAuto || "").trim();
    if (!c) return true;
    if (s && c === s) return true;
    if (a && c === a) return true;
    if (/from-url|sample|demo|ubuntu-20\.04-minimal|nombre de imagen/i.test(c)) return true;
    return false;
  }

  async function getImagesCatalog() {
    try {
      if (window.CloudUI && typeof CloudUI.api === "function") {
        return await CloudUI.api("/api/images");
      }
    } catch (_) {}

    const headers = {};
    const token =
      localStorage.getItem("token") ||
      localStorage.getItem("access_token") ||
      sessionStorage.getItem("token") ||
      sessionStorage.getItem("access_token");

    if (token) headers["Authorization"] = `Bearer ${token}`;

    const r = await fetch("/api/images", { headers });
    if (!r.ok) throw new Error(`No se pudo obtener catálogo: HTTP ${r.status}`);
    return await r.json();
  }

  async function nextAvailableName(base) {
    const safeBase = (base || "").trim();
    if (!safeBase) return "";

    let items = [];
    try {
      items = await getImagesCatalog();
    } catch (_) {
      return safeBase;
    }

    const used = new Set(
      (Array.isArray(items) ? items : [])
        .map(x => normalizeKey(x.name))
        .filter(Boolean)
    );

    if (!used.has(normalizeKey(safeBase))) return safeBase;

    let i = 1;
    while (used.has(normalizeKey(`${safeBase} (${i})`))) {
      i += 1;
    }
    return `${safeBase} (${i})`;
  }

  function findNameInput(scope) {
    return (
      scope.querySelector('input[name="name"]') ||
      scope.querySelector('#name') ||
      scope.querySelector('input[placeholder*="nombre" i]') ||
      scope.querySelector('input[placeholder*="name" i]')
    );
  }

  function attachFileAutoName(fileInput) {
    if (!fileInput || fileInput.dataset.autonameBound === "1") return;
    fileInput.dataset.autonameBound = "1";

    const scope = fileInput.closest("form, .card, section, .panel, .widget, div") || document;
    const nameInput = findNameInput(scope);
    if (!nameInput) return;

    if (!nameInput.dataset.seedValue) {
      nameInput.dataset.seedValue = (nameInput.value || "").trim();
    }
    if (!nameInput.dataset.userEdited) {
      nameInput.dataset.userEdited = "0";
    }

    nameInput.addEventListener("input", () => {
      nameInput.dataset.userEdited = "1";
    });

    fileInput.addEventListener("change", async () => {
      const file = fileInput.files && fileInput.files[0];
      if (!file) return;

      const base = splitBaseName(file.name);
      const current = (nameInput.value || "").trim();
      const seed = nameInput.dataset.seedValue || "";
      const lastAuto = nameInput.dataset.lastAutoName || "";

      if (nameInput.dataset.userEdited === "1" && !looksReplaceable(current, seed, lastAuto)) {
        return;
      }

      const finalName = await nextAvailableName(base);
      nameInput.value = finalName;
      nameInput.dataset.lastAutoName = finalName;
      nameInput.dataset.userEdited = "0";
      nameInput.dispatchEvent(new Event("input", { bubbles: true }));
    });
  }

  function attachUrlAutoName(urlInput) {
    if (!urlInput || urlInput.dataset.autourlBound === "1") return;
    urlInput.dataset.autourlBound = "1";

    const scope = urlInput.closest("form, .card, section, .panel, .widget, div") || document;
    const nameInput = findNameInput(scope);
    if (!nameInput) return;

    if (!nameInput.dataset.seedValue) {
      nameInput.dataset.seedValue = (nameInput.value || "").trim();
    }
    if (!nameInput.dataset.userEdited) {
      nameInput.dataset.userEdited = "0";
    }

    nameInput.addEventListener("input", () => {
      nameInput.dataset.userEdited = "1";
    });

    urlInput.addEventListener("blur", async () => {
      let last = "";
      try {
        const u = new URL((urlInput.value || "").trim());
        last = (u.pathname.split("/").pop() || "").trim();
      } catch (_) {
        return;
      }

      const base = splitBaseName(last);
      const current = (nameInput.value || "").trim();
      const seed = nameInput.dataset.seedValue || "";
      const lastAuto = nameInput.dataset.lastAutoName || "";

      if (nameInput.dataset.userEdited === "1" && !looksReplaceable(current, seed, lastAuto)) {
        return;
      }

      const finalName = await nextAvailableName(base);
      nameInput.value = finalName;
      nameInput.dataset.lastAutoName = finalName;
      nameInput.dataset.userEdited = "0";
      nameInput.dispatchEvent(new Event("input", { bubbles: true }));
    });
  }

  function prettifyResponseArea() {
    const candidates = [...document.querySelectorAll("pre, code")]
      .filter(el => /"name"|stored_filename|size_gb|error|detail/.test(el.textContent || ""));

    for (const box of candidates) {
      if (box.dataset.prettyBound === "1") continue;
      box.dataset.prettyBound = "1";

      const wrap = document.createElement("div");
      wrap.style.marginTop = "10px";
      wrap.style.padding = "12px";
      wrap.style.borderRadius = "14px";
      wrap.style.background = "rgba(10,18,44,.92)";
      wrap.style.border = "1px solid rgba(255,255,255,.08)";
      wrap.style.whiteSpace = "pre-wrap";
      wrap.style.wordBreak = "break-word";
      wrap.style.maxHeight = "280px";
      wrap.style.overflow = "auto";
      wrap.textContent = box.textContent || "";

      const label = document.createElement("div");
      label.style.fontSize = "12px";
      label.style.textTransform = "uppercase";
      label.style.letterSpacing = ".04em";
      label.style.color = "#9db7ff";
      label.style.marginBottom = "8px";
      label.textContent = "Respuesta técnica";

      const parent = box.parentElement;
      if (!parent) continue;
      box.style.display = "none";
      parent.insertBefore(label, box);
      parent.insertBefore(wrap, box);
    }
  }

  function boot() {
    document.querySelectorAll('input[type="file"]').forEach(attachFileAutoName);
    document.querySelectorAll('input[name="url"], #url, input[placeholder*="url" i]').forEach(attachUrlAutoName);
    prettifyResponseArea();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }

  const mo = new MutationObserver(() => boot());
  mo.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>

