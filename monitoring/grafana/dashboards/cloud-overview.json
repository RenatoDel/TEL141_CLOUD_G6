          "expr": "100 - (avg by (node) (rate(node_cpu_seconds_total{job=~\"node_exporter_.*\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "CPU usage %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
