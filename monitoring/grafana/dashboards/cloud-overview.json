      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{job=~\"node_exporter_.*\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{job=~\"node_exporter_.*\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"}))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Disk usage / %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
