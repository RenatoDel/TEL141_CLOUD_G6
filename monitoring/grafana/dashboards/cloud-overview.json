      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{job=~\"node_exporter_.*\"} / 1024 / 1024 / 1024",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Available memory GB",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
