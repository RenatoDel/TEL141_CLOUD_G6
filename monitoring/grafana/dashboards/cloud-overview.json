      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=~\"node_exporter_.*\"} / node_memory_MemTotal_bytes{job=~\"node_exporter_.*\"}))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Memory usage %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
